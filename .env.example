# ─────────────────────────────────────────────────────────────
# Triage — environment configuration
# Copy this file to `.env` and fill in the values. NEVER commit `.env`.
# ─────────────────────────────────────────────────────────────

# ── Slack (from your Slack app config) ──
# Bot token: starts with xoxb-  (OAuth & Permissions page)
SLACK_BOT_TOKEN=xoxb-your-bot-token
# App-level token: starts with xapp-  (Basic Information → App-Level Tokens, scope connections:write)
# Required for Socket Mode (no public URL needed — works behind a corporate firewall).
SLACK_APP_TOKEN=xapp-your-app-token

# ── Claude (the triage brain) ──
ANTHROPIC_API_KEY=sk-ant-your-key
# Defaults to the most capable Claude model if unset. (claude-opus-4-8 | claude-sonnet-4-6 | claude-haiku-4-5)
TRIAGE_MODEL=claude-opus-4-8

# ── GitHub MCP (the context source) ──
# A GitHub token with repo read access (and issues:write to open draft issues).
GITHUB_TOKEN=ghp_your-token
# The default owner/repo Triage investigates when none is specified in the message.
GITHUB_DEFAULT_REPO=owner/repo

# How Triage reaches the GitHub MCP server:
#   "remote" → GitHub's hosted MCP server (https://api.githubcopilot.com/mcp/)  [recommended]
#   "local"  → run the GitHub MCP server locally over stdio (needs Docker or the gh mcp binary)
GITHUB_MCP_MODE=remote
GITHUB_MCP_URL=https://api.githubcopilot.com/mcp/

# ── Behaviour ──
# Max agentic tool-use rounds the brain may take while gathering context.
TRIAGE_MAX_STEPS=6
LOG_LEVEL=info
