# ─────────────────────────────────────────────────────────────
# Triage — environment configuration
# Copy this file to `.env` and fill in the values. NEVER commit `.env`.
# ─────────────────────────────────────────────────────────────

# ── Slack (from your Slack app config) ──
# Bot token: starts with xoxb-  (OAuth & Permissions page)
SLACK_BOT_TOKEN=xoxb-your-bot-token
# App-level token: starts with xapp-  (Basic Information → App-Level Tokens, scope connections:write)
# Required for Socket Mode (no public URL needed — works behind a corporate firewall).
SLACK_APP_TOKEN=xapp-your-app-token

# ── Which brain drives triage: "gemini" (free tier) or "anthropic" (Claude) ──
# gemini   → gathers evidence via the GitHub REST API (no MCP server needed; most reliable behind a firewall).
# anthropic → gathers evidence over the GitHub MCP server (consume-MCP path).
LLM_PROVIDER=gemini

# ── Gemini (used when LLM_PROVIDER=gemini) ──
GEMINI_API_KEY=your-gemini-key
GEMINI_MODEL=gemini-2.5-flash
# Embedding model for incident-memory recall. Run `npm run list:models` to see
# which embedding models your key supports (keys differ — e.g. some expose
# gemini-embedding-001 but not text-embedding-004).
EMBEDDING_MODEL=gemini-embedding-001

# ── Incident memory (Culprit's institutional knowledge of past incidents) ──
INCIDENTS_DB_PATH=data/incidents.json
# Similarity floor for a past incident to count as a match. MEMORY_MIN_SCORE is
# for embedding cosine; MEMORY_MIN_SCORE_LEXICAL is the (much lower) floor for the
# offline lexical fallback. See `npm run verify:memory`.
MEMORY_MIN_SCORE=0.7
MEMORY_MIN_SCORE_LEXICAL=0.12
# Maintain a live Slack Canvas per incident. Needs the canvases:write + files:read
# scopes (reinstall the app after adding them). Set false to disable.
CANVAS_ENABLED=true
MEMORY_RECALL_K=3
# Min similarity (0-1) for a past incident to count as a match. 0.70 suits
# gemini-embedding-001; tune per embedding model (see `npm run verify:memory`).
MEMORY_MIN_SCORE=0.7

# ── Claude (used when LLM_PROVIDER=anthropic) ──
ANTHROPIC_API_KEY=sk-ant-your-key
# Defaults to the most capable Claude model if unset. (claude-opus-4-8 | claude-sonnet-4-6 | claude-haiku-4-5)
TRIAGE_MODEL=claude-opus-4-8

# ── GitHub (the context source) ──
# Token scopes needed for the multi-signal evidence path:
#   read:  Contents, Pull requests, Issues, Metadata   (gather evidence)
#   write: Issues                                       (file the drafted issue from the button)
# A classic PAT with the `repo` scope covers all of these.
GITHUB_TOKEN=ghp_your-token
# The default owner/repo Triage investigates when none is specified in the message.
GITHUB_DEFAULT_REPO=owner/repo
# Optional comma-separated extra repos Culprit may FILE ISSUES into (beyond the
# default). Restricts the bot's write token so a reporter can't target any repo.
GITHUB_ALLOWED_REPOS=

# ── Evidence Hub: plug ANY MCP server in as an evidence source ──
# Comma-separated name=url pairs (Streamable HTTP MCP servers). Their tools join
# the triage loop alongside memory + GitHub — e.g. an error tracker or log search.
#   EVIDENCE_MCP_SERVERS=sentry=https://mcp.sentry.dev/mcp, logs=https://logs.internal/mcp
# Per-source bearer auth via EVIDENCE_MCP_AUTH_<NAME>, e.g. EVIDENCE_MCP_AUTH_SENTRY=...
EVIDENCE_MCP_SERVERS=

# How Triage reaches the GitHub MCP server:
#   "remote" → GitHub's hosted MCP server (https://api.githubcopilot.com/mcp/)  [recommended]
#   "local"  → run the GitHub MCP server locally over stdio (needs Docker or the gh mcp binary)
GITHUB_MCP_MODE=remote
GITHUB_MCP_URL=https://api.githubcopilot.com/mcp/

# ── Behaviour ──
# Max agentic tool-use rounds the brain may take while gathering context.
TRIAGE_MAX_STEPS=8
# Channels Culprit watches for alerts (comma-separated channel IDs). Top-level
# messages there (e.g. Sentry/PagerDuty webhook posts) are auto-triaged.
ALERT_CHANNELS=
# Cap on simultaneous investigations (protects LLM quota during a storm).
MAX_CONCURRENT_TRIAGES=3
# Append-only JSONL trail of write actions (issue filed / resolution logged / forget).
AUDIT_LOG_PATH=data/audit.jsonl
# Optional HTTP liveness endpoint (GET / -> JSON). Leave unset to disable.
HEALTH_PORT=
LOG_LEVEL=info
