{
  "display_information": {
    "name": "Culprit",
    "description": "Report the symptom. Culprit names the cause — root-cause hypothesis, suspected owner, and a draft GitHub issue, built on MCP.",
    "background_color": "#1f2d3d"
  },
  "features": {
    "bot_user": {
      "display_name": "Culprit",
      "always_online": true
    },
    "assistant_view": {
      "assistant_description": "Investigate an incident and get a triaged root-cause hypothesis with evidence.",
      "suggested_prompts": [
        { "title": "Triage an incident", "message": "Checkout is returning 500s repo:owner/repo" }
      ]
    }
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "app_mentions:read",
        "assistant:write",
        "chat:write",
        "im:history",
        "im:read",
        "im:write",
        "channels:history",
        "groups:history",
        "users:read"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "bot_events": [
        "app_mention",
        "assistant_thread_started",
        "message.im"
      ]
    },
    "interactivity": {
      "is_enabled": true
    },
    "socket_mode_enabled": true,
    "org_deploy_enabled": false,
    "token_rotation_enabled": false
  }
}
